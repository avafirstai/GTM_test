# ==========================================
# AVA GTM Dashboard — Environment Variables
# ==========================================
# Copy to .env.local and fill in your values
# NEVER commit actual secrets — only this template

# --- Supabase (Required for dashboard) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# --- Python Scripts (Required for pipeline) ---
# These are used by scripts/email_scraper.py and scripts/import_to_supabase.py
# Set via: export SUPABASE_URL=... && export SUPABASE_ANON_KEY=...
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here

# --- Apify (Google Maps data source) ---
APIFY_TOKEN=apify_api_your_token_here

# --- Instantly.ai (Cold email campaigns — optional) ---
INSTANTLY_API_KEY=your_instantly_api_key_here
INSTANTLY_CAMPAIGN_ID=your_campaign_id_here

# --- GitHub (auto-deploy via run_pipeline.sh — optional) ---
GITHUB_TOKEN=ghp_your_token_here
